SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Token only needed for draft preview
SANITY_API_TOKEN=

# ──────────────────────────────────────────────
# Formulaire de contact — SMTP (Nodemailer)
# ──────────────────────────────────────────────
# Hôte SMTP de ton fournisseur mail
SMTP_HOST=smtp.example.com
# 587 = STARTTLS (recommandé) · 465 = SSL
SMTP_PORT=587
# Identifiant (souvent l'adresse email complète)
SMTP_USER=contact@vincianevinckenbosch.com
# Mot de passe SMTP ou mot de passe d'application
SMTP_PASS=your-smtp-password
# Boîte qui reçoit les messages du formulaire
OWNER_EMAIL=vinciane.vinckenbosch@gmail.com
# Optionnel : adresse "From" affichée (sinon = SMTP_USER)
SMTP_FROM=Vinciane Vinckenbosch <contact@vincianevinckenbosch.com>
