---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/astro/Footer.astro';
import type { Lang } from '../../lib/types';
import { LANGS } from '../../lib/i18n';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const content = {
  fr: {
    title: 'Mentions legales',
    intro: 'Informations legales relatives au site officiel de Vinciane Vinckenbosch.',
    updated: 'Derniere mise a jour : 31 mai 2026',
    sections: [
      {
        title: 'Editeur du site',
        paragraphs: [
          'Ce site est le site officiel de Vinciane Vinckenbosch, altiste.',
          'Responsable du contenu : Vinciane Vinckenbosch.',
          'Email de contact : vinciane.vinckenbosch@gmail.com.',
          'Adresse professionnelle, numero d\'entreprise ou numero de TVA : a completer si applicable.',
        ],
      },
      {
        title: 'Creation du site',
        paragraphs: [
          'Conception et developpement : Isaure Lohest.',
          'Site web : isaure-lohest.com.',
        ],
      },
      {
        title: 'Hebergement',
        paragraphs: [
          'Hebergeur : a completer selon le prestataire utilise pour la mise en ligne du site.',
          'Les informations exactes de l\'hebergeur devront etre ajoutees avant la publication definitive.',
        ],
      },
      {
        title: 'Propriete intellectuelle',
        paragraphs: [
          'Les textes, photographies, images, videos, graphismes, logos et elements de ce site sont proteges par le droit d\'auteur et les droits voisins.',
          'Toute reproduction, distribution, modification ou utilisation sans autorisation prealable est interdite.',
        ],
      },
      {
        title: 'Credits photographiques',
        paragraphs: [
          'Photographies : Andrej Grilc, sauf mention contraire.',
        ],
      },
      {
        title: 'Liens externes',
        paragraphs: [
          'Ce site peut contenir des liens vers des sites externes, notamment YouTube ou les reseaux sociaux. Vinciane Vinckenbosch n\'est pas responsable du contenu ni des pratiques de confidentialite de ces sites tiers.',
        ],
      },
    ],
  },
  en: {
    title: 'Legal Notice',
    intro: 'Legal information about the official website of Vinciane Vinckenbosch.',
    updated: 'Last updated: May 31, 2026',
    sections: [
      {
        title: 'Website Publisher',
        paragraphs: [
          'This website is the official website of Vinciane Vinckenbosch, violist.',
          'Content owner: Vinciane Vinckenbosch.',
          'Contact email: vinciane.vinckenbosch@gmail.com.',
          'Professional address, company number or VAT number: to be completed if applicable.',
        ],
      },
      {
        title: 'Website Creation',
        paragraphs: [
          'Design and development: Isaure Lohest.',
          'Website: isaure-lohest.com.',
        ],
      },
      {
        title: 'Hosting',
        paragraphs: [
          'Hosting provider: to be completed according to the provider used to publish the website.',
          'The exact hosting provider details should be added before final publication.',
        ],
      },
      {
        title: 'Intellectual Property',
        paragraphs: [
          'Texts, photographs, images, videos, graphics, logos and other elements of this website are protected by copyright and related rights.',
          'Any reproduction, distribution, modification or use without prior authorization is prohibited.',
        ],
      },
      {
        title: 'Photo Credits',
        paragraphs: [
          'Photography: Andrej Grilc, unless otherwise stated.',
        ],
      },
      {
        title: 'External Links',
        paragraphs: [
          'This website may contain links to external websites, including YouTube or social networks. Vinciane Vinckenbosch is not responsible for the content or privacy practices of third-party websites.',
        ],
      },
    ],
  },
  de: {
    title: 'Impressum',
    intro: 'Rechtliche Informationen zur offiziellen Website von Vinciane Vinckenbosch.',
    updated: 'Letzte Aktualisierung: 31. Mai 2026',
    sections: [
      {
        title: 'Website-Betreiberin',
        paragraphs: [
          'Diese Website ist die offizielle Website von Vinciane Vinckenbosch, Bratschistin.',
          'Verantwortlich fuer den Inhalt: Vinciane Vinckenbosch.',
          'Kontakt-E-Mail: vinciane.vinckenbosch@gmail.com.',
          'Berufsadresse, Unternehmensnummer oder Umsatzsteuer-Identifikationsnummer: falls zutreffend zu ergaenzen.',
        ],
      },
      {
        title: 'Erstellung der Website',
        paragraphs: [
          'Design und Entwicklung: Isaure Lohest.',
          'Website: isaure-lohest.com.',
        ],
      },
      {
        title: 'Hosting',
        paragraphs: [
          'Hosting-Anbieter: je nach Anbieter, ueber den die Website veroeffentlicht wird, zu ergaenzen.',
          'Die genauen Angaben zum Hosting-Anbieter sollten vor der finalen Veroeffentlichung ergaenzt werden.',
        ],
      },
      {
        title: 'Urheberrecht',
        paragraphs: [
          'Texte, Fotografien, Bilder, Videos, Grafiken, Logos und sonstige Inhalte dieser Website sind urheberrechtlich und leistungsschutzrechtlich geschuetzt.',
          'Jede Vervielfaeltigung, Verbreitung, Bearbeitung oder Nutzung ohne vorherige Genehmigung ist untersagt.',
        ],
      },
      {
        title: 'Bildnachweise',
        paragraphs: [
          'Fotografie: Andrej Grilc, sofern nicht anders angegeben.',
        ],
      },
      {
        title: 'Externe Links',
        paragraphs: [
          'Diese Website kann Links zu externen Websites enthalten, darunter YouTube oder soziale Netzwerke. Vinciane Vinckenbosch ist nicht fuer Inhalte oder Datenschutzpraktiken dieser Drittanbieter-Websites verantwortlich.',
        ],
      },
    ],
  },
}[lang];
---

<BaseLayout
  lang={lang}
  title={`${content.title} — Vinciane Vinckenbosch`}
  description={content.intro}
>
  <main class="legal-page">
    <div class="legal-page__container">
      <header class="legal-page__header" data-reveal>
        <h1 class="section-title legal-page__title">{content.title}</h1>
        <p class="legal-page__intro">{content.intro}</p>
        <p class="legal-page__updated">{content.updated}</p>
      </header>

      <div class="legal-page__content">
        {content.sections.map(section => (
          <section class="legal-page__section" data-reveal>
            <h2>{section.title}</h2>
            {section.paragraphs.map(paragraph => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
.legal-page {
  --page-padding: clamp(1.5rem, 4vw, 4rem);
  min-height: 100vh;
  padding: clamp(4rem, 8vw, 7rem) var(--page-padding);
}

.legal-page__container {
  max-width: 980px;
  margin: 0 auto;
}

.legal-page__header {
  margin-bottom: clamp(3rem, 6vw, 5rem);
}

.legal-page__title {
  margin-bottom: 1.5rem;
  font-size: clamp(2.5rem, 5.5vw, 5.375rem);
  line-height: 1;
  color: #ffffff;
}

.legal-page__intro,
.legal-page__updated,
.legal-page__section p {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  color: #E6E3DB;
}

.legal-page__intro {
  max-width: 42rem;
  font-size: clamp(1.125rem, 1.8vw, 1.45rem);
  line-height: 1.45;
}

.legal-page__updated {
  margin-top: 1.25rem;
  font-size: 0.95rem;
  color: #BCB7A9;
}

.legal-page__content {
  display: grid;
  gap: clamp(2rem, 4vw, 3.5rem);
}

.legal-page__section {
  padding-top: clamp(1.5rem, 3vw, 2rem);
  border-top: 1px solid rgba(230, 227, 219, 0.18);
}

.legal-page__section h2 {
  margin: 0 0 1rem;
  font-family: "Andale Mono", "Courier New", monospace;
  font-size: clamp(0.875rem, 1vw, 1rem);
  line-height: 1.4;
  color: #DA7F52;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.legal-page__section p {
  margin: 0;
  font-size: clamp(1rem, 1.35vw, 1.125rem);
  line-height: 1.65;
}

.legal-page__section p + p {
  margin-top: var(--para-gap);
}
</style>
