---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/astro/Footer.astro';
import AgendaSectionVue from '../../components/vue/AgendaSection.vue';
import type { Lang } from '../../lib/types';
import { LANGS } from '../../lib/i18n';
import { getAgendaEvents } from '../../lib/queries';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const eventsData = await getAgendaEvents(lang);

const pageTitle = {
  fr: 'Archives — Vinciane Vinckenbosch',
  en: 'Archives — Vinciane Vinckenbosch',
  de: 'Archiv — Vinciane Vinckenbosch',
}[lang];
---

<BaseLayout lang={lang} title={pageTitle}>
  <main class="archives-page">
    <AgendaSectionVue
      client:load
      events={eventsData}
      lang={lang}
      showPastOnly={true}
      showAllByDefault={true}
      hideArchivesLink={true}
      hideLinks={true}
      backHref={`/${lang}/#agenda`}
    />
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
.archives-page {
  padding-bottom: 0;
}
</style>
