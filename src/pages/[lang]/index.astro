---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/astro/HeroSection.astro';
import QuoteBlock from '../../components/astro/QuoteBlock.astro';
import BiographySection from '../../components/astro/BiographySection.astro';
import AgendaSection from '../../components/astro/AgendaSection.astro';
import ContactSection from '../../components/astro/ContactSection.astro';
import Footer from '../../components/astro/Footer.astro';
import type { Lang } from '../../lib/types';
import { LANGS } from '../../lib/i18n';
import { getHeroEvents, getHomepage } from '../../lib/queries';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const heroEvents = await getHeroEvents(3);
const homepage = await getHomepage();

const quote2 = {
  fr: '« Une instrumentiste remarquable » et une « musicienne vivante et intéressante ».',
  en: '« A remarkable instrumentalist » and a « lively and interesting musician ».',
  de: '« Eine bemerkenswerte Instrumentalistin » und eine « lebendige und interessante Musikerin ».',
};
---

{(() => {
  const titles = {
    fr: 'Vinciane Vinckenbosch — Altiste belge',
    en: 'Vinciane Vinckenbosch — Belgian Violist',
    de: 'Vinciane Vinckenbosch — Belgische Bratschistin',
  };
  const descs = {
    fr: 'Vinciane Vinckenbosch, altiste belge. Co-solo de la Niederbayerische Philharmonie, soliste, chambriste, membre fondatrice du Trio Linaris. Saluée par la critique internationale pour la grande classe de son jeu.',
    en: 'Vinciane Vinckenbosch, Belgian violist. Co-principal at the Niederbayerische Philharmonie, soloist, chamber musician, founding member of Trio Linaris. Acclaimed by international critics for the great class of her playing.',
    de: 'Vinciane Vinckenbosch, belgische Bratschistin. Co-Solo der Niederbayerischen Philharmonie, Solistin, Kammermusikerin, Gründungsmitglied des Trio Linaris. Von der internationalen Kritik für ihre große Klasse gelobt.',
  };
  return null;
})()}

<BaseLayout
  lang={lang}
  title={{ fr: 'Vinciane Vinckenbosch — Altiste belge', en: 'Vinciane Vinckenbosch — Belgian Violist', de: 'Vinciane Vinckenbosch — Belgische Bratschistin' }[lang]}
  description={{ fr: 'Vinciane Vinckenbosch, altiste belge. Co-solo de la Niederbayerische Philharmonie, soliste, chambriste, membre fondatrice du Trio Linaris. Saluée par la critique internationale pour la grande classe de son jeu.', en: 'Vinciane Vinckenbosch, Belgian violist. Co-principal at the Niederbayerische Philharmonie, soloist, chamber musician, founding member of Trio Linaris. Acclaimed by international critics.', de: 'Vinciane Vinckenbosch, belgische Bratschistin. Co-Solo der Niederbayerischen Philharmonie, Solistin, Kammermusikerin, Gründungsmitglied des Trio Linaris.' }[lang]}
>
  <!-- Hero OUTSIDE main → enfant direct de body, zéro contrainte de conteneur -->
  <HeroSection lang={lang} heroEvents={heroEvents} />
  <main>
    <BiographySection lang={lang} />

    <section class="page-section page-section--padded" data-reveal>
      <QuoteBlock
        quote={quote2[lang]}
        attribution="(Wilfried Strehle, ancien alto solo du Berliner Philharmoniker)"
        size="large"
      />
    </section>

    <AgendaSection lang={lang} />
    <ContactSection
      lang={lang}
      email={homepage?.contactEmail}
      socialLinks={homepage?.socialLinks}
      videoUrl={homepage?.contactVideoUrl}
    />
    <section class="home-final-image" aria-hidden="true" data-reveal>
      <img
        src="/images/grilc-02660.jpg"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
.page-section {
  max-width: 1728px;
  margin: 0 auto;
}

.page-section--padded {
  /* Même padding horizontal que bio__wrap pour aligner les quotes */
  padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 3.7vw, 4rem);
}

.home-final-image {
  max-width: 1728px;
  margin: 0 auto;
  padding: 0 clamp(1.5rem, 4vw, 4rem);
}

.home-final-image img {
  width: 100%;
  aspect-ratio: 1672 / 900;
  object-fit: cover;
  object-position: center;
  display: block;
}
</style>
