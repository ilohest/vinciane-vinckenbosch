---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/astro/HeroSection.astro';
import QuoteBlock from '../../components/astro/QuoteBlock.astro';
import BiographySection from '../../components/astro/BiographySection.astro';
import AgendaSection from '../../components/astro/AgendaSection.astro';
import ContactSection from '../../components/astro/ContactSection.astro';
import BioDownload from '../../components/vue/BioDownload.vue';
import Footer from '../../components/astro/Footer.astro';
import type { Lang } from '../../lib/types';
import { LANGS } from '../../lib/i18n';
import { getHeroEvents, getHomepage, getSocialPreview } from '../../lib/queries';
import { frenchTypo } from '../../lib/typography';
import { sanityImageCropSrcset, sanityImageCropUrl, sanityImageObjectPosition } from '../../lib/sanity-image';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const heroEvents = await getHeroEvents(lang, 3);
const homepage = await getHomepage();
const socialPreview = await getSocialPreview();
const finalImage = homepage?.finalImage || '/images/grilc-02660.jpg';
const finalImageRatio = 1672 / 900;
const finalImageSrc = sanityImageCropUrl(finalImage, 3200, finalImageRatio);
const finalImageSrcset = sanityImageCropSrcset(finalImage, finalImageRatio);
const finalImagePosition = sanityImageObjectPosition(finalImage);
// Image de partage social (Open Graph / Twitter), pilotée uniquement par le Studio.
const ogImage = socialPreview?.image
  ? sanityImageCropUrl(socialPreview.image, 1200, 1200 / 630)
  : undefined;
// PDF de biographie par langue : Sanity en priorité, sinon fichiers locaux
const bioPdfs = {
  fr: homepage?.biographyPdfs?.fr ?? '/pdfs/biographie-fr.pdf',
  en: homepage?.biographyPdfs?.en ?? '/pdfs/biographie-en.pdf',
  de: homepage?.biographyPdfs?.de ?? '/pdfs/biographie-de.pdf',
};

const quote2Fallback = {
  fr: '« Une instrumentiste remarquable » et une « musicienne vivante et intéressante ».',
  en: '« A remarkable instrumentalist » and a « lively and interesting musician ».',
  de: '« Eine bemerkenswerte Instrumentalistin » und eine « lebendige und interessante Musikerin ».',
};

const quote2 = {
  fr: frenchTypo(homepage?.quote2Text?.fr || quote2Fallback.fr),
  en: frenchTypo(homepage?.quote2Text?.en || quote2Fallback.en),
  de: frenchTypo(homepage?.quote2Text?.de || quote2Fallback.de),
};
const quote2AttributionValue = homepage?.quote2Attribution;
const quote2Attribution = typeof quote2AttributionValue === 'string'
  ? quote2AttributionValue
  : quote2AttributionValue?.[lang] || quote2AttributionValue?.fr || '(Wilfried Strehle, ancien alto solo du Berliner Philharmoniker)';

const pageTitles = {
  fr: 'Vinciane Vinckenbosch — Altiste belge',
  en: 'Vinciane Vinckenbosch — Belgian Violist',
  de: 'Vinciane Vinckenbosch — belgische Bratschistin',
};
const socialDescription = socialPreview?.description?.[lang]?.trim() ?? '';

---

<BaseLayout
  lang={lang}
  title={pageTitles[lang]}
  description={socialDescription}
  ogImage={ogImage ?? null}
>
  <HeroSection
    lang={lang}
    heroEvents={heroEvents}
    heroImageUrl={homepage?.heroImage?.url || '/images/grilc-03101.jpg'}
    heroVideoUrl={homepage?.heroVideo?.url}
    heroMobileImageUrl={homepage?.heroMobileImage?.url}
    heroMobileVideoUrl={homepage?.heroMobileVideo?.url}
  />
  <main>
    <BiographySection lang={lang} homepage={homepage} />

    <section class="page-section page-section--padded" data-reveal>
      <QuoteBlock
        quote={quote2[lang]}
        attribution={quote2Attribution}
        size="large"
      />
      <div class="quote-cta-row">
        <BioDownload client:visible lang={lang} pdfs={bioPdfs} />
      </div>
    </section>

    <AgendaSection lang={lang} />
    <ContactSection
      lang={lang}
      socialLinks={homepage?.socialLinks}
      videoUrl={homepage?.contactVideoUrl}
      videoThumbnail={homepage?.contactVideoThumbnail}
      galleryImages={homepage?.contactGalleryImages}
    />
    <section class="home-final-image" aria-hidden="true" data-reveal>
      <img
        src={finalImageSrc}
        srcset={finalImageSrcset || undefined}
        sizes="(max-width: 768px) 100vw, 96vw"
        style={finalImagePosition ? `object-position: ${finalImagePosition}` : undefined}
        alt=""
        loading="lazy"
        decoding="async"
      />
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
.page-section {
  max-width: 1728px;
  margin: 0 auto;
}

.page-section--padded {
  padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 3.7vw, 4rem);
}

.quote-cta-row {
  display: flex;
  justify-content: flex-end;
  margin-top: clamp(2rem, 4vw, 3.5rem);
}

@media (max-width: 768px) {
  .quote-cta-row {
    justify-content: flex-start;
  }
}

.home-final-image {
  width: 100%;
  max-width: 1728px;
  margin: 0 auto;
  padding: clamp(2rem, 4vw, 4rem) clamp(1.5rem, 4vw, 4rem);
}

.home-final-image img {
  width: 100%;
  aspect-ratio: 1672 / 900;
  object-fit: cover;
  object-position: center;
  display: block;
}
</style>
