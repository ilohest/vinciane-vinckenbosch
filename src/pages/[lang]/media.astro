---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/astro/Footer.astro';
import MasonryGallery from '../../components/vue/MasonryGallery.vue';
import type { Lang } from '../../lib/types';
import { LANGS, useTranslations } from '../../lib/i18n';
import { getMediaGalleryItems } from '../../lib/queries';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = useTranslations(lang);

/**
 * Galerie media gérée via Sanity (schéma « mediaItem »), ordonnable par
 * glisser-déposer. Tant que Sanity est vide, on affiche le fallback ci-dessous.
 */
const FALLBACK_MEDIA = [
  { image: '/images/grilc-03101.jpg', downloadUrl: '/images/grilc-03101.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-02541.jpg', downloadUrl: '/images/grilc-02541.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-02660.jpg', downloadUrl: '/images/grilc-02660.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-02173.jpg', downloadUrl: '/images/grilc-02173.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-01839.jpg', downloadUrl: '/images/grilc-01839.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-02056.jpg', downloadUrl: '/images/grilc-02056.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-03039.jpg', downloadUrl: '/images/grilc-03039.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-03046.jpg', downloadUrl: '/images/grilc-03046.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-02256.jpg', downloadUrl: '/images/grilc-02256.jpg', caption: '© Andrej Grilc' },
  { image: '/images/grilc-02439.jpg', downloadUrl: '/images/grilc-02439.jpg', caption: '© Andrej Grilc' },
];

const sanityMedia = await getMediaGalleryItems(lang);
const mediaItems = sanityMedia.length > 0 ? sanityMedia : FALLBACK_MEDIA;

const pageTitle = {
  fr: 'Media — Vinciane Vinckenbosch',
  en: 'Media — Vinciane Vinckenbosch',
  de: 'Medien — Vinciane Vinckenbosch',
}[lang];

const pageDescription = {
  fr: 'Galerie photos et vidéos de Vinciane Vinckenbosch, altiste belge : portraits, concerts, répétitions et performances avec le Trio Linaris et la Niederbayerische Philharmonie.',
  en: 'Photo gallery and videos of Vinciane Vinckenbosch, Belgian violist: portraits, concerts, rehearsals and performances with Trio Linaris and the Niederbayerische Philharmonie.',
  de: 'Fotogalerie und Videos von Vinciane Vinckenbosch, belgische Bratschistin: Porträts, Konzerte, Proben und Auftritte mit dem Trio Linaris und der Niederbayerischen Philharmonie.',
}[lang];

// VideoObject schema pour Google Rich Results
const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "Vinciane Vinckenbosch — Vocalise Op. 3",
  "description": "Performance de Vinciane Vinckenbosch, altiste belge, jouant la Vocalise Op. 3.",
  "thumbnailUrl": "https://i.ytimg.com/vi/zZCX7xCGYc8/hqdefault.jpg",
  "uploadDate": "2024-01-01",
  "contentUrl": "https://www.youtube.com/watch?v=zZCX7xCGYc8",
  "embedUrl": "https://www.youtube-nocookie.com/embed/zZCX7xCGYc8",
  "publisher": {
    "@type": "Person",
    "name": "Vinciane Vinckenbosch",
    "url": "https://vincianevinckenbosch.com"
  }
};

// ImageGallery schema
const gallerySchema = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "name": `${pageTitle}`,
  "description": pageDescription,
  "url": `https://vincianevinckenbosch.com/${lang}/media`,
  "author": {
    "@type": "Person",
    "name": "Vinciane Vinckenbosch"
  }
};
---

<BaseLayout lang={lang} title={pageTitle} description={pageDescription} ogImage="/images/grilc-02541.jpg">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(videoSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(gallerySchema)} />
  <main class="media-page">
    <div class="media-page__container">
      <h1 class="section-title media-page__title" data-reveal>{tr('nav.media')}</h1>
      <MasonryGallery
        client:load
        items={mediaItems}
        lang={lang}
      />
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
.media-page {
  --page-padding: clamp(1.5rem, 4vw, 4rem);
  min-height: 100vh;
  /* Navbar fixe (57px) + padding de page */
  padding-top: calc(var(--navbar-height, 57px) + var(--page-padding));
  padding-bottom: var(--page-padding);
}

.media-page__container {
  max-width: 1728px;
  margin: 0 auto;
  padding: 0 var(--page-padding);
  display: flex;
  flex-direction: column;
  gap: clamp(2.5rem, 4vw, 4rem);
}

.media-page__title {
  font-size: clamp(2.5rem, 5.5vw, 5.375rem);
  color: #ffffff;
}
</style>
