---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/astro/Footer.astro';
import MasonryGallery from '../../components/vue/MasonryGallery.vue';
import type { Lang } from '../../lib/types';
import { LANGS, useTranslations } from '../../lib/i18n';
import { getPressGalleryItems } from '../../lib/queries';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = useTranslations(lang);

/**
 * Articles de presse gérables via Sanity (schéma « pressItem »).
 * `href` est OPTIONNEL : si la source en ligne existe, un bouton « Lire l'article »
 * apparaît dans l'agrandissement. Sinon (article papier/payant), l'image reste
 * consultable en grand sans lien.
 *
 * Tant que Sanity n'est pas rempli, on utilise le fallback ci-dessous.
 */
const FALLBACK_PRESS = [
  {
    image: '/images/press/heilbronner-stimme-2017.jpg',
    caption: 'Heilbronner Stimme — 19 août 2017',
  },
  {
    image: '/images/press/pnp-grosse-kammermusik-2024.jpg',
    caption: 'Passauer Neue Presse — 7 oct. 2024',
    href: 'https://www.pnp.de/lokales/landkreis-passau/grosse-kammermusik-15534642',
  },
  {
    image: '/images/press/reise-kammermusik-2024.jpg',
    caption: 'Reise durch die Welt der Kammermusik',
  },
];

const sanityPress = await getPressGalleryItems();
const pressItems = sanityPress.length > 0 ? sanityPress : FALLBACK_PRESS;

const pageTitle = {
  fr: 'Presse — Vinciane Vinckenbosch',
  en: 'Press — Vinciane Vinckenbosch',
  de: 'Presse — Vinciane Vinckenbosch',
}[lang];

const pageDescription = {
  fr: 'Revue de presse de Vinciane Vinckenbosch : articles et critiques parus dans Passauer Neue Presse, Klassik Heute, La Libre Belgique, Bachtrack et d\'autres médias spécialisés.',
  en: 'Press reviews of Vinciane Vinckenbosch: articles and reviews published in Passauer Neue Presse, Klassik Heute, La Libre Belgique, Bachtrack and other specialist media.',
  de: 'Pressestimmen zu Vinciane Vinckenbosch: Artikel und Kritiken in der Passauer Neuen Presse, Klassik Heute, La Libre Belgique, Bachtrack und anderen Fachmedien.',
}[lang];
---

<BaseLayout lang={lang} title={pageTitle} description={pageDescription} ogImage="/images/grilc-02173.jpg">
  <main class="presse-page">
    <div class="presse-page__container">
      <h1 class="section-title presse-page__title" data-reveal>{tr('nav.presse')}</h1>
      <div>
        <MasonryGallery
          client:only="vue"
          items={pressItems}
          lang={lang}
        />
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
.presse-page {
  --page-padding: clamp(1.5rem, 4vw, 4rem);
  min-height: 100vh;
  /* Navbar fixe (57px) + padding de page */
  padding-top: calc(var(--navbar-height, 57px) + var(--page-padding));
  padding-bottom: var(--page-padding);
}

.presse-page__container {
  max-width: 1728px;
  margin: 0 auto;
  padding: 0 var(--page-padding);
  display: flex;
  flex-direction: column;
  gap: clamp(2rem, 3vw, 3rem);
}

.presse-page__title {
  font-size: clamp(2.5rem, 5.5vw, 5.375rem);
  color: #ffffff;
}

.presse-page__intro {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  font-size: clamp(0.875rem, 1.4vw, 1rem);
  color: #BCB7A9;
  opacity: 0.8;
}
</style>
