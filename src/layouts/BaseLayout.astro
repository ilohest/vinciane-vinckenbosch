---
import '../styles/global.css';
import NavBar from '../components/vue/NavBar.vue';
import { LANGS, localePath } from '../lib/i18n';
import type { Lang } from '../lib/types';
import type { PageKey } from '../lib/routes';
import { pagePath } from '../lib/routes';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  pageKey?: PageKey;
  canonicalPath?: string;
}

const {
  lang,
  title = 'Vinciane Vinckenbosch — Altiste',
  description = 'Vinciane Vinckenbosch, altiste belge. Soliste, chambriste, co-solo de la Niederbayerische Philharmonie.',
  ogImage = '/images/grilc-03101.jpg',
  noindex = false,
  pageKey,
  canonicalPath,
} = Astro.props;

const canonicalURL = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
const alternatePath = (l: Lang) => pageKey ? pagePath(l, pageKey) : localePath(l);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href="https://cdn.sanity.io" />
    <link rel="dns-prefetch" href="https://cdn.sanity.io" />

    <!-- hreflang for i18n -->
    {LANGS.map(l => (
      <link
        rel="alternate"
        hreflang={l}
        href={new URL(alternatePath(l), Astro.site)}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(alternatePath('fr'), Astro.site)} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : lang === 'en' ? 'en_GB' : 'de_DE'} />

    <script is:inline>
      document.documentElement.classList.add('reveal-enabled');
    </script>

    <!-- ── Structured data — Person ──────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Vinciane Vinckenbosch",
      "alternateName": ["Vinciane Vinckenbosch altiste", "Vinciane Vinckenbosch viola"],
      "jobTitle": "Violiste / Altiste",
      "description": "Altiste belge saluée par la critique internationale pour la grande classe de son jeu. Co-solo de la Niederbayerische Philharmonie, membre fondatrice du Trio Linaris, soliste invitée dans de nombreux orchestres européens.",
      "url": "https://vincianevinckenbosch.com",
      "image": "https://vincianevinckenbosch.com/images/grilc-03101.jpg",
      "nationality": { "@type": "Country", "name": "Belgium" },
      "birthPlace": { "@type": "Place", "address": { "@type": "PostalAddress", "addressCountry": "BE" } },
      "knowsAbout": ["Alto", "Viola", "Musique de chambre", "Chamber Music", "Kammermusik", "Musique d'orchestre", "Musique classique"],
      "knowsLanguage": ["fr", "en", "de"],
      "sameAs": [
        "https://www.youtube.com/@vincianevinckenbosch",
        "https://www.instagram.com/vinciane.vinckenbosch",
        "https://www.facebook.com/vinciane.vinckenbosch"
      ],
      "memberOf": {
        "@type": "MusicGroup",
        "name": "Trio Linaris",
        "description": "Trio pour flûte, alto et harpe fondé par Vinciane Vinckenbosch, Pierre Cornu-Deyme et Alexandra Bidi."
      },
      "alumniOf": [
        {
          "@type": "EducationalOrganization",
          "name": "Hochschule für Musik und Tanz Köln",
          "address": { "@type": "PostalAddress", "addressLocality": "Cologne", "addressCountry": "DE" }
        },
        {
          "@type": "EducationalOrganization",
          "name": "Haute École de Musique de Genève",
          "address": { "@type": "PostalAddress", "addressLocality": "Geneva", "addressCountry": "CH" }
        },
        {
          "@type": "EducationalOrganization",
          "name": "Institut royal de Musique et de Pédagogie de Namur",
          "address": { "@type": "PostalAddress", "addressLocality": "Namur", "addressCountry": "BE" }
        }
      ],
      "award": [
        "Soutien Yamaha Music Foundation of Europe",
        "Fonds Thirionet",
        "Tonkünstler Live Special 2025 et 2026 — Ministère bavarois de la Culture"
      ],
      "performer": true,
      "email": "vinciane.vinckenbosch@gmail.com"
    })} />

    <!-- ── Structured data — WebSite ──────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Vinciane Vinckenbosch",
      "description": "Site officiel de Vinciane Vinckenbosch, altiste belge.",
      "url": "https://vincianevinckenbosch.com",
      "inLanguage": ["fr", "en", "de"],
      "author": {
        "@type": "Person",
        "name": "Vinciane Vinckenbosch"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://vincianevinckenbosch.com/fr/#agenda?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/Coconat-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/OrticaLinear-Light.woff2" as="font" type="font/woff2" crossorigin />

    <meta name="theme-color" content="#232323" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  </head>
  <body>
    <slot />
    <NavBar client:idle lang={lang} currentPath={Astro.url.pathname} />

    <!-- ── Curseur personnalisé — point orange (desktop only) ── -->
    <div id="custom-cursor" aria-hidden="true"></div>

    <script is:inline>
      /* ── Scroll reveal ──────────────────────────────────── */
      function initReveal() {
        const targets = document.querySelectorAll('[data-reveal]');
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced || !('IntersectionObserver' in window)) {
          targets.forEach(el => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
        targets.forEach(el => io.observe(el));
      }

      /* ── LQIP blur-up : images lazy ─────────────────────── */
      function initBlurUp() {
        document.querySelectorAll('img[loading="lazy"]').forEach(img => {
          if (img.complete && img.naturalWidth > 0) {
            img.classList.add('img-loaded');
          } else {
            img.addEventListener('load', () => img.classList.add('img-loaded'), { once: true });
            img.addEventListener('error', () => img.classList.add('img-loaded'), { once: true });
          }
        });
      }

      /* ── Curseur personnalisé ────────────────────────────── */
      function initCursor() {
        const cursor = document.getElementById('custom-cursor');
        if (!cursor) return;
        // Masqué sur touch
        if (!window.matchMedia('(hover: hover)').matches) {
          cursor.style.display = 'none';
          return;
        }

        let cx = -100, cy = -100;

        document.addEventListener('mousemove', e => {
          cx = e.clientX;
          cy = e.clientY;
          cursor.style.transform = `translate(${cx}px, ${cy}px)`;
        }, { passive: true });

        document.addEventListener('mouseleave', () => cursor.classList.add('cursor--hidden'));
        document.addEventListener('mouseenter', () => cursor.classList.remove('cursor--hidden'));

        // Agrandir sur éléments interactifs
        function addHover(selector) {
          document.querySelectorAll(selector).forEach(el => {
            el.addEventListener('mouseenter', () => cursor.classList.add('cursor--hover'));
            el.addEventListener('mouseleave', () => cursor.classList.remove('cursor--hover'));
          });
        }
        addHover('a, button, [role="button"], label[for]');
      }

      /* ── Init & re-init après View Transitions ───────────── */
      function initAll() {
        initReveal();
        initBlurUp();
        initCursor();
      }

      initAll();
    </script>
  </body>
</html>
