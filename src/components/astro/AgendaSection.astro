---
import AgendaSectionVue from '../vue/AgendaSection.vue';
import type { Lang } from '../../lib/types';
import type { AgendaEvent } from '../../lib/queries';
import { getAgendaEvents } from '../../lib/queries';

interface Props {
  lang: Lang;
  events?: AgendaEvent[];
}

const { lang, events } = Astro.props;

const allEventsData = events ?? await getAgendaEvents(lang);

function startDateIso(dateIso: string, timeStr: string): string {
  const time = timeStr.replace('h', ':').padEnd(5, '00');
  return `${dateIso}T${time}:00`;
}

const eventSchemas = allEventsData.map(e => ({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": `Concert de Vinciane Vinckenbosch — ${e.role}`,
  "description": `${e.role} — Programme : ${(e.program ?? []).join(', ')}`,
  "startDate": startDateIso(e.dateIso, e.time ?? '20:00'),
  "location": {
    "@type": "Place",
    "name": e.venue,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": e.city.split(',')[0].trim(),
      "addressCountry": e.city.split(',')[1]?.trim() ?? 'DE',
    }
  },
  "performer": {
    "@type": "Person",
    "name": "Vinciane Vinckenbosch",
    "url": "https://vincianevinckenbosch.com"
  },
  "organizer": { "@type": "Organization", "name": e.venue },
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  ...(e.ticketUrl ? { "offers": {
    "@type": "Offer",
    "url": e.ticketUrl,
    "availability": "https://schema.org/InStock"
  }} : {})
}));
---

<!-- JSON-LD Event — aide Google Rich Results -->
{eventSchemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

<!-- Filtrage past/upcoming géré côté client dans le composant Vue -->
<AgendaSectionVue client:visible events={allEventsData} lang={lang} />
