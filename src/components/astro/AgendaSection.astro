// Convertir les dates FR lisibles en ISO 8601 pour Schema.org
function toISO(dateStr: string, timeStr: string): string {
  const months: Record<string, string> = {
    'jan': '01', 'fév': '02', 'mar': '03', 'avr': '04',
    'mai': '05', 'jun': '06', 'juil': '07', 'aoû': '08',
    'sep': '09', 'oct': '10', 'nov': '11', 'déc': '12',
    'juin': '06', 'juillet': '07', 'août': '08', 'sept': '09',
  };
  const parts = dateStr.toLowerCase().replace('.', '').split(' ');
  const day   = parts[0].padStart(2, '0');
  const month = months[parts[1]] ?? '01';
  const year  = parts[2] ?? '2026';
  const time  = timeStr.replace('h', ':').padEnd(5, '00');
  return `${year}-${month}-${day}T${time}:00`;
}

const eventSchemas = events.map(e => ({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": `Concert de Vinciane Vinckenbosch — ${e.role}`,
  "description": `${e.role} — Programme : ${e.program.join(', ')}`,
  "startDate": toISO(e.date, e.time ?? '20:00'),
  "location": {
    "@type": "Place",
    "name": e.venue,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": e.city.split(',')[0].trim(),
      "addressCountry": e.city.split(',')[1]?.trim() ?? 'DE',
    }
  },
  "performer": {
    "@type": "Person",
    "name": "Vinciane Vinckenbosch",
    "url": "https://vincianevinckenbosch.com"
  },
  "organizer": {
    "@type": "Organization",
    "name": e.venue
  },
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  ...(e.ticketUrl ? { "offers": {
    "@type": "Offer",
    "url": e.ticketUrl,
    "availability": "https://schema.org/InStock"
  }} : {})
}));
---

<!-- JSON-LD Event pour chaque concert — aide Google Rich Results -->
{eventSchemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

<AgendaSectionVue client:load events={events} lang={lang} />
