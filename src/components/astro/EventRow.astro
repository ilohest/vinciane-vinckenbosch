---
import type { Lang } from '../../lib/types';

interface Props {
  date: string;
  time?: string;
  city: string;
  venue: string;
  role: string;
  program?: string[];
  lang: Lang;
}

const { date, time, city, venue, role, program = [] } = Astro.props;
---

<article class="event">
  <div class="event__date-col">
    <time class="event__date section-title">{date}</time>
    {time && <span class="event__time section-title">{time}</span>}
  </div>
  <div class="event__city">{city}</div>
  <div class="event__venue">{venue}</div>
  <div class="event__role">{role}</div>
  {program.length > 0 && (
    <ul class="event__program" aria-label="Programme">
      {program.map(p => <li>{p}</li>)}
    </ul>
  )}
</article>

<style>
.event {
  display: grid;
  grid-template-columns: 12rem 8rem 1fr 10rem auto;
  gap: 2rem;
  align-items: center;
  min-height: 12rem;
  padding: 1.5rem 0;
}

.event__date-col {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  gap: 0.5rem;
}

.event__date {
  font-size: clamp(1.25rem, 2.5vw, 2.5rem);
  color: #ffffff;
  line-height: 1;
}

.event__time {
  font-size: clamp(1rem, 1.8vw, 1.8125rem);
  color: #ffffff;
}

.event__city,
.event__venue,
.event__role {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  font-size: clamp(0.875rem, 1.4vw, 1.0625rem);
  color: #ffffff;
  align-self: center;
}

.event__role {
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: clamp(0.8125rem, 1.3vw, 1.0625rem);
}

.event__program {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 2px;
  align-self: center;
}

.event__program li {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  font-size: clamp(0.8125rem, 1.2vw, 0.9375rem);
  color: #ffffff;
  opacity: 0.8;
}

@media (max-width: 900px) {
  .event {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    gap: 0.75rem;
    min-height: unset;
    padding: 1.25rem 0;
  }
  .event__date-col {
    grid-column: 1;
    grid-row: 1;
    flex-direction: row;
    gap: 0.75rem;
    align-items: baseline;
  }
  .event__city  { grid-column: 2; grid-row: 1; }
  .event__venue { grid-column: 1; grid-row: 2; }
  .event__role  { grid-column: 2; grid-row: 2; }
  .event__program { grid-column: 1 / -1; grid-row: 3; }
}
</style>
