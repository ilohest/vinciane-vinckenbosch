---
import type { Lang, SanityImageAsset } from '../../lib/types';
import { useTranslations } from '../../lib/i18n';
import { sanityImageCropSrcset, sanityImageCropUrl, sanityImageObjectPosition } from '../../lib/sanity-image';
import { pagePath } from '../../lib/routes';
import ContactForm from '../vue/ContactForm.vue';

interface Props {
  lang: Lang;
  email?: string;
  socialLinks?: { youtube?: string; facebook?: string; instagram?: string };
  videoUrl?: string;
  videoThumbnail?: SanityImageAsset;
  galleryImages?: SanityImageAsset[];
}

const {
  lang,
  email = 'vinciane.vinckenbosch@gmail.com',
  socialLinks = { youtube: '#', facebook: '#', instagram: '#' },
  videoUrl = 'https://www.youtube.com/watch?v=zZCX7xCGYc8',
  videoThumbnail,
  galleryImages,
} = Astro.props;

const tr = useTranslations(lang);
const getYouTubeId = (url: string): string | null => {
  try {
    const parsedUrl = new URL(url);
    const hostname = parsedUrl.hostname.replace(/^www\./, '');

    if (hostname === 'youtu.be') {
      return parsedUrl.pathname.split('/').filter(Boolean)[0] ?? null;
    }

    if (hostname.endsWith('youtube.com')) {
      if (parsedUrl.pathname === '/watch') return parsedUrl.searchParams.get('v');
      const [, type, id] = parsedUrl.pathname.split('/');
      if (['embed', 'shorts', 'live'].includes(type)) return id ?? null;
    }
  } catch {
    return null;
  }

  return null;
};

const contactVideoId = getYouTubeId(videoUrl) ?? 'zZCX7xCGYc8';
const contactVideoUrl = `https://www.youtube-nocookie.com/embed/${contactVideoId}`;
const contactVideoThumbnail = videoThumbnail ?? `https://i.ytimg.com/vi/${contactVideoId}/hqdefault.jpg`;

const FALLBACK_GALLERY = [
  '/images/grilc-02256.jpg',
  '/images/grilc-02541.jpg',
  '/images/grilc-02173.jpg',
  '/images/grilc-02439.jpg',
];

const resolvedGallery = galleryImages && galleryImages.length > 0
  ? galleryImages.filter((img) => img?.asset?._ref || img?.url)
  : FALLBACK_GALLERY;

const CONTACT_THUMB_RATIO = 4 / 3;
const CONTACT_VIDEO_RATIO = 16 / 9;

const contactGalleryItems = resolvedGallery.slice(0, 4).map((src) => ({
  src: sanityImageCropUrl(src, 1200, CONTACT_THUMB_RATIO),
  srcset: sanityImageCropSrcset(src, CONTACT_THUMB_RATIO),
  position: sanityImageObjectPosition(src),
}));

const resolvedContactVideoThumbnail = sanityImageCropUrl(contactVideoThumbnail, 1800, CONTACT_VIDEO_RATIO);
const contactVideoThumbnailSrcset = sanityImageCropSrcset(contactVideoThumbnail, CONTACT_VIDEO_RATIO);
const contactVideoThumbnailPosition = sanityImageObjectPosition(contactVideoThumbnail);
---

<section class="contact" id="contact" aria-labelledby="contact-title">
  <div class="contact__container">

        <div class="contact__header" data-reveal>
      <h2 id="contact-title" class="section-title contact__title">{tr('contact.title')}</h2>
      <div class="contact__socials">
        {socialLinks.youtube && (
          <a href={socialLinks.youtube} target="_blank" rel="noopener noreferrer" class="contact__social-link">
            Youtube
          </a>
        )}
        {socialLinks.facebook && (
          <a href={socialLinks.facebook} target="_blank" rel="noopener noreferrer" class="contact__social-link">
            Facebook
          </a>
        )}
        {socialLinks.instagram && (
          <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" class="contact__social-link">
            Instagram
          </a>
        )}
      </div>
    </div>

        <div class="contact__form-wrap" data-reveal>
      <ContactForm client:visible lang={lang} />
    </div>

        <div class="contact__media-row" data-reveal>
      <div class="contact__gallery">
        {contactGalleryItems.map(image => (
          <div class="contact__thumb">
            <img
              src={image.src}
              srcset={image.srcset || undefined}
              sizes="(max-width: 900px) 50vw, 25vw"
              style={image.position ? `object-position: ${image.position}` : undefined}
              alt="Vinciane Vinckenbosch"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>

      <div class="contact__media-bottom">
        <div class="contact__video-preview">
          <button
            type="button"
            class="contact__video-trigger"
            data-youtube-src={contactVideoUrl}
            aria-label="Lire la vidéo YouTube de Vinciane Vinckenbosch"
          >
            <img
              src={resolvedContactVideoThumbnail}
              srcset={contactVideoThumbnailSrcset || undefined}
              sizes="(max-width: 900px) 100vw, 50vw"
              style={contactVideoThumbnailPosition ? `object-position: ${contactVideoThumbnailPosition}` : undefined}
              alt=""
              loading="lazy"
              decoding="async"
            />
            <span class="contact__play-icon" aria-hidden="true"></span>
          </button>
        </div>
        <a href={pagePath(lang, 'media')} class="btn-pill contact__media-link">
          {tr('media.cta')}
        </a>
      </div>
    </div>

  </div>
</section>

<style>
.contact {
  padding: clamp(5rem, 8vw, 9rem) 0 clamp(4rem, 6vw, 6rem);
}

.contact__container {
  max-width: 1728px;
  margin: 0 auto;
  padding: 0 clamp(1.5rem, 4vw, 4rem);
  display: flex;
  flex-direction: column;
  gap: clamp(3rem, 5vw, 6rem);
}

.contact__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.contact__title {
  font-size: clamp(2.5rem, 5.5vw, 5.375rem);
  line-height: 1;
  color: #ffffff;
}

.contact__socials {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--para-gap);
}

.contact__social-link {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  font-size: clamp(0.875rem, 1.4vw, 1.0625rem);
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  text-decoration: none;
  transition: color 0.2s ease;
}

.contact__social-link:hover {
  color: #DA7F52;
}

.contact__email-wrap {
  align-self: flex-end;
  text-align: right;
  margin-top: clamp(3rem, 8vw, 8rem);
}

.contact__email {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  font-size: clamp(1.25rem, 2.4vw, 2.5rem);
  color: #F7F5F3;
  word-break: break-all;
  transition: color 0.2s ease;
    text-decoration: none;
  position: relative;
  display: inline-block;
}

.contact__email::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  width: 100%;
  height: 1px;
  background-color: currentColor;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

.contact__email:hover {
  color: #DA7F52;
}

.contact__email:hover::after {
  transform: scaleX(1);
}

@media (hover: none) {
  .contact__email {
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
  }
  .contact__email::after { display: none; }
}

.contact__form-wrap {
  max-width: 720px;
  margin-top: clamp(1rem, 3vw, 2rem);
}

.contact__media-row {
  display: flex;
  flex-direction: column;
  gap: clamp(1.5rem, 2.5vw, 3rem);
}

.contact__gallery {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: clamp(0.5rem, 1vw, 1rem);
}

.contact__thumb {
  aspect-ratio: 3/2;
  overflow: hidden;
}

.contact__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.contact__thumb:hover img {
  transform: scale(1.04);
}

.contact__media-bottom {
  display: grid;
  grid-template-columns: minmax(18rem, 49.5%) 1fr;
  align-items: end;
  gap: clamp(2rem, 4vw, 5rem);
}

.contact__media-link {
  justify-self: end;
}

.contact__video-preview {
  position: relative;
  aspect-ratio: 16/9;
  overflow: hidden;
  background-color: #111111;
}

.contact__video-trigger {
  width: 100%;
  height: 100%;
  border: 0;
  padding: 0;
  display: block;
  position: relative;
  cursor: pointer;
  background-color: #111111;
}

.contact__video-trigger img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transition: transform 0.4s ease, opacity 0.2s ease;
}

.contact__video-trigger:hover img {
  transform: scale(1.03);
  opacity: 0.88;
}

.contact__play-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  width: clamp(3.25rem, 7vw, 5rem);
  aspect-ratio: 1;
  transform: translate(-50%, -50%);
  border: 1px solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  background-color: rgba(17, 17, 17, 0.28);
  backdrop-filter: blur(8px);
}

.contact__play-icon::before {
  content: "";
  position: absolute;
  left: 52%;
  top: 50%;
  transform: translate(-42%, -50%);
  width: 0;
  height: 0;
  border-top: 0.65rem solid transparent;
  border-bottom: 0.65rem solid transparent;
  border-left: 1rem solid #ffffff;
}

.contact__video-preview iframe {
    position: absolute;
  inset: 0;
  border: 0;
  width: 100%;
  height: 100%;
  display: block;
}

@media (max-width: 900px) {
  .contact__gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .contact__media-bottom {
    grid-template-columns: 1fr;
  }
  .contact__media-link {
    justify-self: start;
  }
}

@media (max-width: 768px) {

  .contact {
    padding: clamp(3rem, 8vw, 5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .contact__container {
    gap: clamp(1.5rem, 6vw, 2.5rem);
  }

    .contact__header {
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(1.5rem, 6vw, 2rem);
  }

    .contact__title {
    font-size: clamp(2.5rem, 11.2vw, 2.8125rem);
  }

    .contact__socials {
    align-items: flex-start;
    gap: 0.5625rem;   }

  .contact__social-link {
    font-size: 0.9375rem;   }

    .contact__email-wrap {
    align-self: flex-start;
    text-align: left;
    margin-top: 0;   }

  .contact__email {
    font-size: 1.25rem;   }

  .contact__media-row {
    display: flex;
    gap: clamp(1.25rem, 6vw, 2rem);
    margin-top: clamp(0.75rem, 3vw, 1.25rem);
  }

  .contact__gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .contact__thumb {
    aspect-ratio: 4/3;
  }

  .contact__media-bottom {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .contact__video-preview {
    width: 100%;
  }

  .contact__media-link {
    justify-self: auto;
  }
}
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.contact__video-trigger').forEach((button) => {
    button.addEventListener('click', () => {
      const videoSrc = button.dataset.youtubeSrc;
      if (!videoSrc) return;

      const iframe = document.createElement('iframe');
      iframe.src = `${videoSrc}?autoplay=1&rel=0`;
      iframe.title = button.getAttribute('aria-label') ?? 'YouTube video';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      // Plein écran dans le conteneur aspect-ratio
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';

      button.replaceWith(iframe);
    });
  });
</script>
