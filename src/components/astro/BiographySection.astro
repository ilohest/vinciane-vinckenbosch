---
import type { Homepage, Lang } from '../../lib/types';
import { useTranslations } from '../../lib/i18n';
import { frenchTypo } from '../../lib/typography';
import { sanityImageCropSrcset, sanityImageCropUrl, sanityImageObjectPosition } from '../../lib/sanity-image';

interface Props {
  lang: Lang;
  homepage?: Homepage | null;
}

const { lang, homepage } = Astro.props;
const tr = useTranslations(lang);

/** Texte d'un champ bio localisé : Sanity (langue → fr) sinon fallback FR codé en dur */
const bio = (field: keyof Homepage, fallback: string): string => {
  const v = homepage?.[field] as { fr?: string; en?: string; de?: string } | undefined;
  return (v && (v[lang] || v.fr)) || fallback;
};

// Citation d'ouverture (Sanity → fallback)
const heroQuote = frenchTypo(
  (homepage?.heroQuote?.[lang] || homepage?.heroQuote?.fr)
  || 'Saluée par la critique internationale pour la « grande classe » de son jeu, Vinciane Vinckenbosch mène une carrière artistique riche et multiple, entre scène soliste, musique de chambre et orchestre.'
);
const heroQuoteAttr = homepage?.heroQuoteAttribution || '(Passauer Neue Presse)';

// ── Images : Sanity en priorité, fallback sur les fichiers locaux ──
const imgIntro      = homepage?.biographyIntroImage || '/images/biographie-portrait-blue-viola.jpg';
const imgPortrait1  = homepage?.bioImage2           || '/images/grilc-02541.jpg';
const imgTrioNarrow = homepage?.trioImageNarrow     || '/images/trio-linaris-studio-portrait.jpg';
const imgTrioWide   = homepage?.trioImageWide       || '/images/trio-linaris-harp-room.jpeg';
const imgPortrait2  = homepage?.bioImage3           || '/images/grilc-02173.jpg';
const imgFormation  = homepage?.bioFormationImage   || '/images/grilc-02256.jpg';

const INTRO_RATIO = 1099 / 628;
const PORTRAIT_TALL_RATIO = 798 / 919;
const TRIO_NARROW_RATIO = 532 / 726;
const TRIO_WIDE_RATIO = 1060 / 726;
const PORTRAIT_RATIO = 803 / 881;
const LANDSCAPE_RATIO = 803 / 535;

const imgIntroSrcset      = sanityImageCropSrcset(imgIntro, INTRO_RATIO);
const imgPortrait1Srcset  = sanityImageCropSrcset(imgPortrait1, PORTRAIT_TALL_RATIO);
const imgTrioNarrowSrcset = sanityImageCropSrcset(imgTrioNarrow, TRIO_NARROW_RATIO);
const imgTrioWideSrcset   = sanityImageCropSrcset(imgTrioWide, TRIO_WIDE_RATIO);
const imgPortrait2Srcset  = sanityImageCropSrcset(imgPortrait2, PORTRAIT_RATIO);
const imgFormationSrcset  = sanityImageCropSrcset(imgFormation, LANDSCAPE_RATIO);

const imgIntroPosition      = sanityImageObjectPosition(imgIntro);
const imgPortrait1Position  = sanityImageObjectPosition(imgPortrait1);
const imgTrioNarrowPosition = sanityImageObjectPosition(imgTrioNarrow);
const imgTrioWidePosition   = sanityImageObjectPosition(imgTrioWide);
const imgPortrait2Position  = sanityImageObjectPosition(imgPortrait2);
const imgFormationPosition  = sanityImageObjectPosition(imgFormation);

const trioFallback = "Chambriste passionnée, Vinciane Vinckenbosch est membre fondatrice du Trio Linaris, qu'elle forme aux côtés du flûtiste Pierre Cornu-Deyme et de la harpiste Alexandra Bidi (harpe solo de l'Orchestre de Paris).";
const fullTrioText = (homepage?.bioTrioText?.[lang] || homepage?.bioTrioText?.fr) || trioFallback;

const bacriParagraph = {
  fr: {
    before: "Dans ce contexte, elle assurera en septembre 2026",
    accent: "la création mondiale d'une œuvre pour alto",
    after: "de Nicolas Bacri, aux côtés du pianiste Jean-Baptiste Fonlupt.",
  },
  en: {
    before: "In this context, in September 2026 she will give",
    accent: "the world premiere of a work for viola",
    after: "by Nicolas Bacri, alongside pianist Jean-Baptiste Fonlupt.",
  },
  de: {
    before: "In diesem Zusammenhang wird sie im September 2026",
    accent: "die Uraufführung eines Werks für Bratsche",
    after: "von Nicolas Bacri an der Seite des Pianisten Jean-Baptiste Fonlupt übernehmen.",
  },
}[lang];

const trioLinks = (homepage?.trioLinks ?? []).filter((l) => l?.label?.trim());
const trioLinkMap = new Map<string, string | undefined>();
for (const l of trioLinks) {
  const label = l.label!.trim();
  const pdfHref = l.pdf ? `${l.pdf}?dl=${encodeURIComponent(l.pdfName ?? 'document.pdf')}` : undefined;
  trioLinkMap.set(label, pdfHref || l.url?.trim());
}

type TrioHit = { start: number; end: number; label: string };
const trioHits: TrioHit[] = [];
for (const label of [...trioLinkMap.keys()].sort((a, b) => b.length - a.length)) {
  let idx = fullTrioText.indexOf(label);
  while (idx !== -1) {
    if (!trioHits.some((h) => idx < h.end && idx + label.length > h.start)) {
      trioHits.push({ start: idx, end: idx + label.length, label });
    }
    idx = fullTrioText.indexOf(label, idx + label.length);
  }
}
trioHits.sort((a, b) => a.start - b.start);

type TrioPart =
  | { kind: 'text'; value: string }
  | { kind: 'link'; href: string; value: string };
const trioParts: TrioPart[] = [];
let trioCursor = 0;
const pushTrioText = (text: string) => {
  if (text) trioParts.push({ kind: 'text', value: text });
};
for (const h of trioHits) {
  pushTrioText(fullTrioText.slice(trioCursor, h.start));
  const href = trioLinkMap.get(h.label);
  if (href) trioParts.push({ kind: 'link', href, value: h.label });
  else trioParts.push({ kind: 'text', value: h.label });
  trioCursor = h.end;
}
pushTrioText(fullTrioText.slice(trioCursor));
---

<section class="bio" id="biographie">
  <div class="bio__wrap">

    <!-- ════════════════════════════════════════════════════════
         RANGÉE 1 — Citation (gauche ~80%) + attribution (droite)
         Figma : Frame 1000001808 — row, justify: space-between,
                 align: flex-end, width: 1672
    ═════════════════════════════════════════════════════════ -->
    <div class="bio__quote-row" data-reveal>
      <p class="bio__quote-text">{heroQuote}</p>
      <span class="bio__quote-attr">{heroQuoteAttr}</span>
    </div>

    <!-- ════════════════════════════════════════════════════════
         RANGÉE 2 — Titre "BIOGRAPHIE" (gauche) + photo (droite)
         Figma : Frame 1000001830 — row, justify: space-between,
                 align: flex-end, width: 1669
                 Image : 1099×628 → ratio 1.75
    ═════════════════════════════════════════════════════════ -->
    <div class="bio__title-row" data-reveal>
      <h2 class="bio__section-title">{tr('bio.title')}</h2>
      <div class="bio__intro-img-wrap">
        <picture>
          {typeof imgIntro === 'string' && imgIntro === '/images/biographie-portrait-blue-viola.jpg' && (
            <source
              type="image/webp"
              srcset="/images/biographie-portrait-blue-viola-828w.webp 828w,
                      /images/biographie-portrait-blue-viola-1200w.webp 1200w,
                      /images/biographie-portrait-blue-viola-2400w.webp 2400w"
              sizes="(max-width: 768px) 100vw, 66vw"
            />
          )}
          {imgIntroSrcset && (
            <source srcset={imgIntroSrcset} sizes="(max-width: 768px) 100vw, 66vw" />
          )}
          <img
            src={sanityImageCropUrl(imgIntro, 2400, INTRO_RATIO)}
            alt="Vinciane Vinckenbosch — portrait officiel, altiste belge"
            class="bio__intro-img"
            style={imgIntroPosition ? `object-position: ${imgIntroPosition}` : undefined}
            loading="lazy"
            decoding="async"
            width="2400"
            height="1600"
          />
        </picture>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════
         BLOC 1 — Image gauche (798×919, portrait ~47.7%)
                 + texte droite (789px ~47.2%)
         Figma : Frame 1000001825 — row, justify: space-between
    ═════════════════════════════════════════════════════════ -->
    <div class="bio__row bio__row--img-left" data-reveal>
      <div class="bio__img-wrap bio__img-wrap--portrait-tall">
        <picture>
          {typeof imgPortrait1 === 'string' && imgPortrait1 === '/images/grilc-02541.jpg' && (
            <source
              type="image/webp"
              srcset="/images/grilc-02541-828w.webp 828w,
                      /images/grilc-02541-1600w.webp 1600w,
                      /images/grilc-02541-2500w.webp 2500w"
              sizes="(max-width: 768px) 100vw, 48vw"
            />
          )}
          {imgPortrait1Srcset && (
            <source srcset={imgPortrait1Srcset} sizes="(max-width: 768px) 100vw, 48vw" />
          )}
          <img
            src={sanityImageCropUrl(imgPortrait1, 2400, PORTRAIT_TALL_RATIO)}
            alt="Vinciane Vinckenbosch jouant de l'alto, portrait artistique"
            style={imgPortrait1Position ? `object-position: ${imgPortrait1Position}` : undefined}
            loading="lazy"
            decoding="async"
            width="9504"
            height="6336"
          />
        </picture>
      </div>
      <div class="bio__text-col">
        <p class="bio__p">{bio('bioParaOrchestre', `Régulièrement invitée en tant qu'alto solo par plusieurs orchestres européens, elle collabore notamment avec l'Orchestre symphonique de Porto à la Casa da Música, l'Orchestre philharmonique de Ratisbonne, le Clara-Schumann Philharmoniker et l'Opéra Royal de Wallonie. Elle se produit entre autres sous la direction de chefs tels que Christian Zacharias, Stefan Blunier, Paul Weikert et Giampaolo Bisanti. Elle occupe parallèlement le poste d'alto co-solo de la Niederbayerische Philharmonie depuis 2018.`)}</p>
        <p class="bio__p">{bio('bioParaPrix', `Lauréate de plusieurs concours nationaux et internationaux destinés aux jeunes talents, elle a également bénéficié du soutien de la Yamaha Music Foundation of Europe et du Fonds Thirionet.`)}</p>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════
         TEXTE TRIO LINARIS — pleine largeur, 56px
         Liens éditables depuis Sanity
         Figma : style_7U6T38, fontSize 56, lineHeight 64px
    ═════════════════════════════════════════════════════════ -->
    <p class="bio__trio-text" data-reveal>
      {trioParts.map((part) => {
        if (part.kind === 'text') return part.value;
        if (part.kind === 'link') {
          return (
            <a
              href={part.href}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                'bio__trio-link',
                part.value === 'Trio Linaris' && 'bio__trio-link--accent',
              ]}
            >{part.value}</a>
          );
        }
      })}
    </p>

    <!-- ════════════════════════════════════════════════════════
         IMAGES TRIO — deux photos côte à côte
         Figma : 532×726 (33%) + 1060×726 (67%), gap: 80px
    ═════════════════════════════════════════════════════════ -->
    <div class="bio__trio-imgs" data-reveal>
      <div class="bio__trio-img bio__trio-img--narrow">
        <picture>
          {imgTrioNarrowSrcset && (
            <source srcset={imgTrioNarrowSrcset} sizes="(max-width: 768px) 100vw, 33vw" />
          )}
          <img
            src={sanityImageCropUrl(imgTrioNarrow, 1600, TRIO_NARROW_RATIO)}
            alt="Vinciane Vinckenbosch — Trio Linaris"
            style={imgTrioNarrowPosition ? `object-position: ${imgTrioNarrowPosition}` : undefined}
            loading="lazy"
            decoding="async"
            width="532"
            height="726"
          />
        </picture>
      </div>
      <div class="bio__trio-img bio__trio-img--wide">
        <picture>
          {imgTrioWideSrcset && (
            <source srcset={imgTrioWideSrcset} sizes="(max-width: 768px) 100vw, 67vw" />
          )}
          <img
            src={sanityImageCropUrl(imgTrioWide, 2400, TRIO_WIDE_RATIO)}
            alt="Trio Linaris en salle de concert"
            style={imgTrioWidePosition ? `object-position: ${imgTrioWidePosition}` : undefined}
            loading="lazy"
            decoding="async"
            width="1060"
            height="726"
          />
        </picture>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════
         BLOC 2 — Image gauche (803×881) + texte droite
         Figma : Frame 1000001828 — row, justify: space-between
    ═════════════════════════════════════════════════════════ -->
    <div class="bio__row bio__row--img-left" data-reveal>
      <div class="bio__img-wrap bio__img-wrap--portrait">
        <picture>
          {imgPortrait2Srcset && (
            <source srcset={imgPortrait2Srcset} sizes="(max-width: 768px) 100vw, 48vw" />
          )}
          <img
            src={sanityImageCropUrl(imgPortrait2, 2400, PORTRAIT_RATIO)}
            alt="Vinciane Vinckenbosch en concert, altiste"
            style={imgPortrait2Position ? `object-position: ${imgPortrait2Position}` : undefined}
            loading="lazy"
            decoding="async"
            width="803"
            height="881"
          />
        </picture>
      </div>
      <div class="bio__text-col">
        <p class="bio__p">{bio('bioParaFestivals', `Invitée régulière de festivals en Europe et aux États-Unis, elle partage la scène aux côtés d'artistes tels que Philippe Graffin, Petru Iuga, Ariadne Daskalakis, Julie Sévilla-Fraysse, Philippe Zuckerman, Nazareno Ferruggio, Sodi Braide et Silvia Denk.`)}</p>
        <p class="bio__p">{bio('bioParaSoliste', `Elle se produit également en soliste avec orchestre, notamment avec le Concertino Ensemble d'Augsbourg, l'Orchestre des étudiants de l'IMEP et l'Orchestre symphonique de Namur.`)}</p>
        <p class="bio__p">{bio('bioParaTonkuenstler', `En 2026, Vinciane Vinckenbosch bénéficie, pour la deuxième année consécutive, du soutien du ministère bavarois de la Culture dans le cadre du programme « Tonkünstler Live Special », qui distingue son engagement en faveur de la musique de chambre et de la scène musicale indépendante.`)}</p>
        <p class="bio__p">
          {bacriParagraph.before}{' '}
          <span class="text-accent">{bacriParagraph.accent}</span>
          {' '}{bacriParagraph.after}
        </p>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════
         BLOC 3 — Texte gauche + (image 803×535 + texte) droite
         Figma : Frame 1000001829 — row, justify: space-between
    ═════════════════════════════════════════════════════════ -->
    <div class="bio__row bio__row--text-left" data-reveal>
      <div class="bio__text-col">
        <p class="bio__p">{bio('bioParaFormationViolon', `Après avoir débuté ses études à Bruxelles auprès de Shirly Laub, Vinciane Vinckenbosch obtient en 2011 un Master en violon avec la plus grande distinction dans la classe d'Igor Tkatchouk, à l'Institut royal de Musique et de Pédagogie de Namur. Parallèlement, elle découvre l'alto auprès de Daniel Rubenstein, avant de poursuivre son perfectionnement en violon en Allemagne dans la classe de Petru Munteanu, au Leopold Mozart College of Music de l'université d'Augsbourg.`)}</p>
      </div>
      <div class="bio__right-col">
        <div class="bio__img-wrap bio__img-wrap--landscape">
          <picture>
            {imgFormationSrcset && (
              <source srcset={imgFormationSrcset} sizes="(max-width: 768px) 100vw, 48vw" />
            )}
            <img
              src={sanityImageCropUrl(imgFormation, 2400, LANDSCAPE_RATIO)}
              alt="Vinciane Vinckenbosch — Formation"
              style={imgFormationPosition ? `object-position: ${imgFormationPosition}` : undefined}
              loading="lazy"
              decoding="async"
              width="803"
              height="535"
            />
          </picture>
        </div>
        <div class="bio__text-col">
          <p class="bio__p">{bio('bioParaFormationAlto', `Elle se consacre ensuite pleinement à l'alto à la Haute École de Musique de Genève, puis à la Hochschule für Musik und Tanz de Cologne dans la classe de Matthias Buchholz. Sélectionnée pour représenter la Hochschule de Cologne à New York lors de concerts de musique de chambre en partenariat avec la Juilliard School, elle obtient en 2016 un Master en alto avec la plus haute mention.`)}</p>
          <p class="bio__p">{bio('bioParaMaitres', `Son parcours se nourrit également des précieux conseils d'Augustin Dumay, Boris Kuschnir, Atar Arad, Walter Küssner et Wilfried Strehle.`)}</p>
          <p class="bio__p">{bio('bioParaPedagogie', `Parallèlement à sa carrière d'interprète, Vinciane Vinckenbosch se passionne pour la pédagogie. Elle joue un alto du luthier Nicolas Gilles, réalisé en 2015.`)}</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
/* ── Conteneur ────────────────────────────────────────────── */
.bio {
  padding-top: clamp(2rem,8vw,3rem);
  padding-bottom: 0;
}

.bio__wrap {
  max-width: 1728px;
  margin: 0 auto;
  /* Figma : 28px left inset dans un 1728px frame */
  padding: 0 clamp(1.5rem, 3.7vw, 4rem);
  display: flex;
  flex-direction: column;
  /* Figma Frame 24 : gap 80px */
  gap: clamp(3rem, 5.5vw, 5rem);
}

/* ── RANGÉE 1 — Citation ──────────────────────────────────── */
/*
  Figma Frame 1000001808 :
  row, justify-content: space-between, align-items: flex-end
  Quote : width 1332 / 1672 = 79.7%
  Attribution : width ~265 / 1672 = 15.9%, right side
*/
.bio__quote-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 2rem;
}

.bio__quote-text {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  /* Figma : 85px / 1728px = 4.92vw */
  font-size: clamp(2rem, 4.9vw, 5.3125rem);
  line-height: 1.06;
  /* Indentation de la première ligne (suit la taille du texte) */
  text-indent: 3em;
  color: #DA7F52;
  /* Prend ~80% de la largeur */
  flex: 0 0 calc(79.7% - 1rem);
  max-width: calc(79.7% - 1rem);
}

.bio__quote-attr {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  /* Figma : 23px */
  font-size: clamp(0.8125rem, 1.33vw, 1.4375rem);
  color: #F7F5F3;
  opacity: 0.75;
  flex-shrink: 1;
  max-width: 55%;
  text-align: right;
  /* bottom-aligned : aligné en bas grâce au align-items: flex-end du parent */
  padding-bottom: 0.25rem;
}

/* ── RANGÉE 2 — Titre + photo intro ──────────────────────── */
/*
  Figma Frame 1000001830 :
  row, justify-content: space-between, align-items: flex-end
  Titre : hug (gauche)
  Image : 1099×628 → ~65.8% de 1669px
*/
.bio__title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 2rem;
}

.bio__section-title {
  font-family: "Coconat", Georgia, serif;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  /* Figma : 73px / 1728px = 4.22vw */
  font-size: clamp(2.25rem, 4.2vw, 4.5625rem);
  line-height: 0.84;
  color: #ffffff;
  flex-shrink: 0;
  /* Aligne en bas de la photo */
  padding-bottom: 0.5rem;
}

.bio__intro-img-wrap {
  /* Figma : 1099/1669 = 65.8% */
  flex: 0 0 65.8%;
  max-width: 65.8%;
  aspect-ratio: 1099 / 628;
  overflow: hidden;
}

.bio__intro-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

/* ── Blocs biographie alternés ───────────────────────────── */
/*
  Figma Frame ZWMDHS : row, justify-content: space-between
  Gauche ~47.7% (798/1672) | Droite ~47.2% (789/1672)
*/
.bio__row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: clamp(1.5rem, 3vw, 3rem);
}

/* Image à gauche */
.bio__row--img-left .bio__img-wrap {
  /* Figma : 798/1672 = 47.7% */
  flex: 0 0 47.7%;
  max-width: 47.7%;
}

.bio__row--img-left .bio__text-col {
  /* Figma : 789/1672 = 47.2% */
  flex: 0 0 47.2%;
  max-width: 47.2%;
}

/* Texte à gauche + colonne droite composée */
.bio__row--text-left > .bio__text-col {
  flex: 0 0 47.7%;
  max-width: 47.7%;
}

.bio__right-col {
  flex: 0 0 47.2%;
  max-width: 47.2%;
  display: flex;
  flex-direction: column;
  gap: clamp(1.5rem, 3vw, 3rem);
}

.bio__right-col .bio__text-col {
  width: 100%;
  max-width: 100%;
}

/* ── Wrappers d'images avec aspect ratio Figma ───────────── */
.bio__img-wrap {
  overflow: hidden;
}

.bio__img-wrap--portrait-tall {
  /* Figma : 798×919 → ratio 0.868 */
  aspect-ratio: 798 / 919;
}

.bio__img-wrap--portrait {
  /* Figma : 803×881 → ratio 0.912 */
  aspect-ratio: 803 / 881;
}

.bio__img-wrap--landscape {
  /* Figma : 803×535 → ratio 1.501 */
  aspect-ratio: 803 / 535;
}

.bio__img-wrap picture,
.bio__img-wrap img {
  width: 100%;
  height: 100%;
  display: block;
}

.bio__img-wrap img {
  object-fit: cover;
}

/* ── Colonne texte ────────────────────────────────────────── */
.bio__text-col {
  display: flex;
  flex-direction: column;
  gap: var(--para-gap); /* global --para-gap ≈ 10px */
}

.bio__p {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  /* Figma : 26px / 1728px = 1.505vw */
  font-size: clamp(0.9375rem, 1.5vw, 1.625rem);
  color: #F7F5F3;
  line-height: 1.55;
}

/* ── Texte Trio Linaris ───────────────────────────────────── */
/*
  Figma style_7U6T38 : Ortica 56px, lineHeight 64px
  Prend toute la largeur du conteneur
*/
.bio__trio-text {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  /* Figma : 56px / 1728px = 3.24vw */
  font-size: clamp(1.5rem, 3.24vw, 3.5rem);
  line-height: 1.14;
  color: var(--color-text);
  overflow-wrap: break-word;
  /*
    1ère ligne indentée pour s'aligner avec le bord gauche de la colonne
    de texte du bloc précédent (image 47.7% + gap entre colonnes).
    Dans le Figma : espaces préfixes dans le texte créent cet effet.
  */
  /*
    Avec justify-content:space-between, le gap = 100% - 47.7% (img) - 47.2% (texte) = 5.1%
    → colonne texte commence à 47.7% + 5.1% = 52.8% du container
  */
  text-indent: 52.8%;
}

.bio__trio-link {
  color: inherit;
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 0.18em;
  text-decoration-color: currentColor;
}

.bio__trio-link--accent {
  color: var(--color-accent);
}

