---

interface Props {
  quote: string;
  attribution?: string;
  size?: 'large' | 'medium';
}

const { quote, attribution, size = 'large' } = Astro.props;
---

<blockquote class:list={['quote', `quote--${size}`]} >
  <p class="quote__text" set:html={quote} />
  {attribution && (
    <cite class="quote__attr">{attribution}</cite>
  )}
</blockquote>

<style>
.quote {
  font-style: normal;
    display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 2rem;
}

.quote__text {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
  color: #DA7F52;
    line-height: 1.06;
    text-indent: 3em;
  flex: 0 0 calc(79.7% - 1rem);
  max-width: calc(79.7% - 1rem);
}

.quote--large .quote__text {
  font-size: clamp(2rem, 4.9vw, 5.3125rem);
}

.quote--medium .quote__text {
  font-size: clamp(1.25rem, 3vw, 3rem);
}

.quote__attr {
  font-family: "Ortica Linear", Georgia, serif;
  font-weight: 300;
    font-size: clamp(0.8125rem, 1.33vw, 1.4375rem);
  color: #F7F5F3;
  font-style: normal;
  opacity: 0.75;
  text-align: right;
  flex-shrink: 1;
  max-width: 55%;
    padding-bottom: 0.25rem;
}

@media (max-width: 768px) {
  .quote {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .quote__text {
    flex: none;
    max-width: 100%;
  }
  .quote__attr {
    text-align: right;
    align-self: flex-end;
    white-space: normal;
  }
}

@media (max-width: 480px) {
  .quote__text {
    font-size: 1.65rem;
    line-height: 1.08;
    text-align: end;
    text-indent: 0;
  }

  .quote__attr {
    text-align: end;
  }
}
</style>
