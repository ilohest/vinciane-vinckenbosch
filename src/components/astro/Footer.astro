---
interface Props {
  lang: 'fr' | 'en' | 'de';
}

const { lang } = Astro.props;

const footerLabels = {
  fr: {
    legal: 'Mentions légales',
    privacy: 'Confidentialité',
    credits: 'Crédits photo',
  },
  en: {
    legal: 'Legal',
    privacy: 'Privacy',
    credits: 'Photo Credits',
  },
  de: {
    legal: 'Impressum',
    privacy: 'Datenschutz',
    credits: 'Bildnachweise',
  },
}[lang];
---

<footer class="footer" role="contentinfo">
  <div class="footer__content">

    <!-- Big name -->
    <div class="footer__name-wrap" aria-hidden="true">
      <p class="footer__name">Vinciane Vinckenbosch</p>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <div class="footer__meta">
        <nav class="footer__links" aria-label="Legal">
          <a href={`/${lang}/credits`} class="footer__link">{footerLabels.credits}</a>
          <a href={`/${lang}/legal`} class="footer__link">{footerLabels.legal}</a>
          <a href={`/${lang}/privacy`} class="footer__link">{footerLabels.privacy}</a>
        </nav>
      </div>
      <span class="footer__made-by">
        WEBSITE BY <a href="https://isaure-lohest.com/" target="_blank" rel="noopener noreferrer" class="footer__made-by-link">ISAURE</a>
      </span>
    </div>
  </div>
</footer>

<style>
.footer {
  overflow: hidden;
}

.footer__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}

/* Big name */
.footer__name-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(3rem, 6vw, 5rem) clamp(0.75rem, 2vw, 2rem);
  overflow: hidden;
      padding-bottom: 1rem;
}

.footer__name {
  font-family: "Coconat", Georgia, serif;
  font-weight: 400;
  font-size: min(10.125rem, 9.4vw);
  line-height: 1;
  color: #E6E3DB;
  text-align: center;
  white-space: nowrap;
  letter-spacing: -0.01em;
  max-width: 100%;
}

/* Bottom credits */
.footer__bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  padding: 1.125rem 2rem;
  border-top: 1px solid rgba(230, 227, 219, 0.15);
}

.footer__meta {
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.footer__made-by,
.footer__link {
  font-family: "Andale Mono", "Courier New", monospace;
  font-size: clamp(0.75rem, 0.8vw, 0.875rem);
  color: #E6E3DB;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  opacity: 0.7;
}

.footer__links {
  display: flex;
  align-items: center;
  gap: 0.7rem;
}

.footer__link {
  display: inline-block;
  font-size: clamp(0.68rem, 0.72vw, 0.78rem);
  text-transform: none;
  letter-spacing: 0.02em;
  opacity: 0.65;
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s ease, opacity 0.2s ease;
}

.footer__link + .footer__link::before {
  content: "/";
  margin-right: 0.7rem;
  color: #E6E3DB;
  opacity: 0.65;
}

.footer__link:hover {
  color: #DA7F52;
  opacity: 1;
}

.footer__made-by-link {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 3px;
}

@media (max-width: 768px) {
  .footer__name {
    font-size: 9.2vw;
  }

  .footer__bottom {
    --footer-mobile-gap: 0.55rem;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--footer-mobile-gap);
  }

  .footer__meta {
    display: contents;
  }

  .footer__made-by {
    order: 2;
  }

  .footer__links {
    order: 1;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--footer-mobile-gap);
  }

  .footer__link + .footer__link::before {
    content: none;
  }
}
</style>
